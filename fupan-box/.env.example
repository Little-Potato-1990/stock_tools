DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fupan_box
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/fupan_box
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=change-me-to-a-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

DATA_SOURCE=akshare
TUSHARE_TOKEN=

AI_FREE_QUOTA_DAILY=5

# 开发模式: backend 启动时自动拉起 celery worker + beat 子进程, 一个命令跑全栈.
# 生产 (docker-compose) 应设 0, 让 worker / beat 各自独立服务管理.
DEV_EMBED_CELERY=1
DEV_EMBED_CELERY_CONCURRENCY=2
